# Reddit API
# Get these at: https://www.reddit.com/prefs/apps
# Create a "script" type app. redirect_uri = http://localhost
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=ContentBot/1.0 by YourRedditUsername

# ElevenLabs
# Optional for production-quality voice. Only needed when TTS_ENGINE=elevenlabs.
# Get your key at: https://elevenlabs.io -> Profile -> API Key
# Voice IDs: https://api.elevenlabs.io/v1/voices
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Pexels
# Free at: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# Anthropic
# Optional. Only needed when SCRIPT_ENGINE=anthropic.
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-opus-4-8

# Tavily
# Get at: https://app.tavily.com/home -> API Keys
TAVILY_API_KEY=your_tavily_key_here

# Pipeline defaults
PIPELINE_DEFAULT_MODE=spiritual
SCRIPT_ENGINE=template
TTS_ENGINE=local
LOCAL_TTS_VOICE=Samantha
SPIRITUAL_TOPIC=
DAILY_RUN_HOUR=8
