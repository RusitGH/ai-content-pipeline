# ── Reddit API ────────────────────────────────────────────────
# Get these at: https://www.reddit.com/prefs/apps
# Create a "script" type app. redirect_uri = http://localhost
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=ContentBot/1.0 by YourRedditUsername

# ── ElevenLabs ────────────────────────────────────────────────
# Get your key at: https://elevenlabs.io → Profile → API Key
# Voice IDs: https://api.elevenlabs.io/v1/voices (with your key)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)

# ── Pexels ────────────────────────────────────────────────────
# Free at: https://www.pexels.com/api/ (no credit card needed)
PEXELS_API_KEY=your_pexels_key_here

# ── Anthropic ─────────────────────────────────────────────────
# Get at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Tavily ────────────────────────────────────────────────────
# Used for: news / history / spiritual modes
# Get at: https://app.tavily.com/home → API Keys (free tier = 1000 credits/mo)
TAVILY_API_KEY=your_tavily_key_here
